    "lodash": "^4.17.23",
    "morgan": "^1.10.1",
    "next": "^15.5.14",
    "nodemon": "^3.1.11",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/express": "^4.17.25",
    "@types/lodash": "^4.17.21",
    "@types/node": "^22.19.3",
    "@types/react": "^17.0.90",
    "@types/react-dom": "^17.0.26",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
